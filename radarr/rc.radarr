#!/bin/bash
# ----------------------------------------------------------------------
#
# Slackware init script for Radarr:
# /etc/rc.d/rc.radarr
#
# ----------------------------------------------------------------------

PRGNAM=radarr
SRVCNAM=Radarr
RADARR_USER=@RADARR_USER@
RADARR_GROUP=@RADARR_GROUP@
DATA_DIR="/var/lib/$PRGNAM"
DAEMON="/usr/lib/radarr/bin/Radarr"
DAEMON_OPTS="-nobrowser -data=$DATA_DIR"
PIDFILE=$DATA_DIR/$PRGNAM.pid

start() {
	# Check if already running
	if pgrep -a -F $PIDFILE 2>/dev/null | grep -q $SRVCNAM; then
		echo "$SRVCNAM appears to already be running."
		exit 1

	elif [ $(pidof $SRVCNAM) >/dev/null ]; then

		if [ -r $PIDFILE ]; then
			echo "$SRVCNAM apears to already be running as service $(pidof $SRVCNAM) with a stale lock file at $PIDFILE."
			exit 1
		fi

		echo "$SRVCNAM appears to be running as service $(pidof $SRVCNAM) without a lock file at $PIDFILE."
		exit 1
	fi

	# Create working directory if it doesn't exist
	if [ ! -d $DATA_DIR ]; then
		mkdir -p $DATA_DIR
		if [ $? -ne 0 ]; then
			echo "Error creating $DATA_DIR."
			exit 1
		fi
	fi

	# Take ownership of the working directory
	chown -R $RADARR_USER:$RADARR_GROUP $DATA_DIR
	if [ $? -ne 0 ]; then
		echo "Error setting ownership of $DATA_DIR."
		exit 1
	fi

	# Start the service
	rm -f $PIDFILE
	cd $DATA_DIR
	echo "Starting $SRVCNAM"
	su -m $RADARR_USER -s /bin/bash -c \
		"exec -a $SRVCNAM $DAEMON $DAEMON_OPTS &" >/dev/null 2>&1

	# Check that it worked
	# Use the following if service creates its own lock file
	wait=10
	while [ $wait -gt 0 ]; do
		if pgrep -a -F $PIDFILE 2>/dev/null | grep -q $SRVCNAM; then
			exit 0
		fi
		sleep 1
		(( wait -- ))
	done
	
	if [ $(pidof $SRVCNAM) >/dev/null ]; then
	    echo "Error: $SRVCNAM appears to be running as service $(pidof $SRVCNAM) without a lock file at $PIDFILE."
	    exit 1
	fi

	# Use the following for services that do not create their own lock file
	# wait=15
	#while [ $wait -gt 0 ]; do
	#    PID=$(pidof $SRVCNAM)
	#    if [ $PID ]; then
	#	echo $PID > $PIDFILE
	#	exit 0
	#    fi
	#    sleep 1
	#    (( wait -- ))
	#done

	echo "Error starting $SRVCNAM."
	exit 1

}

stop() {
	if pgrep -a -F $PIDFILE 2>/dev/null | grep -q $SRVCNAM; then
		echo "Stopping $SRVCNAM"
		kill -15 $(cat $PIDFILE)
		wait=10
		while [ $wait -gt 0 ]; do
			if ! pgrep -a -F $PIDFILE 2>/dev/null | grep -q $SRVCNAM; then
				rm -f $PIDFILE
				exit 0
			fi
			sleep 1
			(( wait -- ))
		done
		if [ $(pidof $SRVCNAM) >/dev/null ]; then
		    echo "$SRVCNAM appears to be running without a lock file at $PIDFILE as process $(pidof $SRVCNAM)."
		    exit 1
		fi
		echo "Error stopping $SRVCNAM."
		exit 1
	fi
	echo "$SRVCNAM does not appear to be running."
	exit 1
}

case "$1" in
    start)
	start
	;;
    stop)
	stop
	;;
    status)
	if pgrep -a -F $PIDFILE 2>/dev/null | grep -q $SRVCNAM; then
	    echo "$SRVCNAM running as process $(cat $PIDFILE)"
	    exit 0
    elif [ $(pidof $SRVCNAM) >/dev/null ]; then
	    echo "$SRVCNAM appears to be running without a lock file at $PIDFILE as process $(pidof $SRVCNAM)."
		exit 1
    	else
	    echo "$SRVCNAM is stopped."
	    exit 1
	fi
	;;
    *)
	echo "Usage start|stop|status"
	;;
esac

exit 0
