#!/bin/bash

PRGNAM=sonarr
PRG_USER=sonarr
PRG_GROUP=sonarr
DATA_DIR="/var/lib/$PRGNAM"
BASE_DIR="/opt/$PRGNAM"
DAEMON="/usr/bin/mono --debug $BASE_DIR/${PRGNAM^}"
DAEMON_OPTS="-nobrowser -data=$DATA_DIR"
PIDFILE=$DATA_DIR/$PRGNAM.pid

set -e

start() {

    # Create data directory if it doesn't exist
    if [[ ! -d $DATA_DIR ]]; then
	mkdir -p $DATA_DIR
    fi

    # Make sure we own the base and data directory
	chown -R $PRG_USER:$PRG_GROUP $BASE_DIR
	chown -R $PRG_USER:$PRG_GROUP $DATA_DIR

    if [[ -e $PIDFILE ]]; then
	ps -p $PIDFILE -o comm= 2>/dev/null
	RETVAL=$?
	if [[ $RETVAL == 0 ]]; then
	    echo "$PRGNAM appears to already be running."
	    exit 1
	fi
    else 
	rm -f $PIDFILE
    fi

    echo "Starting $PRGNAM..."
    su - $PRG_USER -s /bin/bash -c 'nohup $DAEMON $DAEMON_OPTS >/dev/null 2>&1 < /dev/null &'
    exit 0
}

stop() {
    if [[ ! -e $PIDFILE ]]; then
	echo "$PRGNAM does not appear to be running."
	exit 1
    else
	killall $(cat $PIDFILE) 2>/dev/null
	RETVAL=$?
	if [[ $RETVAL != 0 ]]; then
	    echo "$PRGNAM does not appear to be running."
	else
	    echo "Stopping $PRGNAM..."
	fi
	rm -r $PIDFILE
	exit $RETVAL
    fi
}

case "$1" in
    start)
	start
	;;
    stop)
	stop
	;;
    restart)
	stop
	sleep 5
	start
    *)
	echo "Usage start|stop|restart"
	;;
esac

exit 0
