#!/bin/sh
# Start/stop the NZBget daemon.
#
USER=nzbget
PRGNAM=nzbget
PREFIX=/usr/bin
BIN=$PREFIX/$PRGNAM

case "$1" in
start)   echo -n "Start services: NZBget"
$BIN -o DaemonUsername=$USER --daemon
;;
stop)   echo -n "Stop services: NZBget"
$BIN --quit
;;
*)   echo "Usage: $0 start|stop"
exit 1
;;
esac
exit 0
